<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.FireTv.Button" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/selector_tv_button</item>
        <item name="android:textColor">@color/selector_tv_button_text</item>
        <item name="backgroundTint">@null</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="android:paddingStart">28dp</item>
        <item name="android:paddingEnd">28dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Widget.FireTv.FocusableText" parent="Widget.AppCompat.TextView">
        <item name="android:background">@drawable/selector_tv_focusable_panel</item>
        <item name="android:textColor">@color/selector_tv_text</item>
        <item name="android:focusable">true</item>
        <item name="android:focusableInTouchMode">true</item>
        <item name="android:padding">16dp</item>
    </style>

    <style name="Widget.FireTv.FocusableText.Secondary">
        <item name="android:textColor">@color/selector_tv_text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

</resources>
